    # CLI
    fd
    ripgrep
    fzf
    zoxide
    eza
    fastfetch
    htop
    bat
    highlight
    xclip
    wl-clipboard
    jq
    poppler
    resvg
    unzip
    woeusb
    lm_sensors
    xdotool
    appimage-run

    # AI
    qwen-code
    opencode

    # Shell utils
    i3lock-color
    wlr-randr
    feh
    scrot
  ];
}
