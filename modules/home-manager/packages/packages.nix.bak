{ pkgs, ... }:

{
  home.packages = with pkgs; [
    # Editor
    zed-editor
    vimgolf

    hugo
    zola

    # GUI
    discord
    libreoffice
    zathura
    planify
    obsidian
    joplin-desktop

    godot

